RWStructuredBuffer<ZoneInput> _M0Input;
RWStructuredBuffer<ZoneInput> _M1Input;
RWStructuredBuffer<ZoneInput> _M2Input;
RWStructuredBuffer<ZoneInput> _M3Input;
RWStructuredBuffer<ZoneInput> _B0Input;
RWStructuredBuffer<ZoneInput> _B1Input;
RWStructuredBuffer<ZoneInput> _B2Input;

uint _F0Active;
uint _M0Active;
uint _M1Active;
uint _M2Active;
uint _M3Active;
uint _B0Active;
uint _B1Active;
uint _B2Active;

uint _F0SpriteCount;
uint _M0SpriteCount;
uint _M1SpriteCount;
uint _M2SpriteCount;
uint _M3SpriteCount;
uint _B0SpriteCount;
uint _B1SpriteCount;
uint _B2SpriteCount;

RWStructuredBuffer<uint> _F0DeadCount;
RWStructuredBuffer<uint> _M0DeadCount;
RWStructuredBuffer<uint> _M1DeadCount;
RWStructuredBuffer<uint> _M2DeadCount;
RWStructuredBuffer<uint> _M3DeadCount;
RWStructuredBuffer<uint> _B0DeadCount;
RWStructuredBuffer<uint> _B1DeadCount;
RWStructuredBuffer<uint> _B2DeadCount;

uint _BackgroundMaskCount;

float3 _SpawnerMinPos;
float3 _SpawnerMaxPos;
float3 _SpawnerSize;

uint _ForegroundParticleCount;
uint _MiddlegroundParticleCount;
uint _BackgroundParticleCount;

float _CamVelocity;
float _TrainVelocity;

uint _Awake;

void InitOutput(int id, int particleCount, int spriteCount, float minPos, float sizeRange, float offset, RWStructuredBuffer<ZoneInput> input, inout ZoneOutput output)
{
    output = (ZoneOutput)0;
    float normID = (float) id / (float) particleCount;
    output.position.z = minPos + (normID * sizeRange);
    output.parallaxFactor = ((_SpawnerMaxPos.z - output.position.z) / _SpawnerMaxPos.z);
    
    uint seed = id ^ asuint(offset * 123.456);
    
    output.randID = HashIntToInt(seed + output.randID);
    output.rand01 = HashIntTo01Float(output.randID);
    
    uint randMod = output.randID % spriteCount;
    
    ZoneInput i = input[randMod];
    
    output.uvSizeAndPos = i.uvSizeAndPos;   
    output.position.xy = i.worldPivotAndSize.xy;
    output.worldPivotAndSize.zw = i.worldPivotAndSize.zw;
    output.scale.xy = float2(1, 1);
    
    output.alive = 1;
    
    output.position.x = _SpawnerSize.x * output.rand01;
    if (_Awake == 1)
    {
        output.position.x += _SpawnerMaxPos.x;
    }
    else
    {
        output.position.x += _SpawnerMinPos.x;
    }
}

void InitSliceOutput(uint id, int particleCount, int spriteCount, float minPos, float sizeRange, float offset, RWStructuredBuffer<ZoneInput> input, inout ZoneOutput output)
{
    output = (ZoneOutput) 0;
    int sliceID = floor((float)id / 9.0);
    
    float sliceParticleCount = floor((float) particleCount / 9.0);
    float normID = sliceID / sliceParticleCount;
    
    output.position.z = minPos + (normID * sizeRange);
    output.parallaxFactor = ((_SpawnerMaxPos.z - output.position.z) / _SpawnerMaxPos.z);
    
    uint seed = sliceID ^ asuint(offset * 123.456);
    
    output.randID = HashIntToInt(seed + output.randID);
    output.rand01 = HashIntTo01Float(output.randID);
    
    uint randMod =  output.randID % spriteCount;
    randMod = (randMod / 9) * 9;
    randMod += id % 9;
    
    ZoneInput i = input[randMod];
    
    float2 scale = float2(5 * output.rand01, 20 * output.rand01);
    
    output.uvSizeAndPos = i.uvSizeAndPos;
    
    output.worldPivotAndSize.xy = -i.worldPivotAndSize.xy + (i.sliceOffsetAndSize.xy * scale);
    output.worldPivotAndSize.zw = i.worldPivotAndSize.zw;
    
    output.scale.xy = max(saturate(ceil(i.sliceOffsetAndSize.zw)) * scale, float2(1, 1));
    
    output.alive = 1;
    
    output.position.x = _SpawnerSize.x * output.rand01;
    if (_Awake == 1)
    {
        output.position.x += _SpawnerMaxPos.x;
    }
    else
    {
        output.position.x += _SpawnerMinPos.x;
    }
}

void UpdateOutput(inout ZoneOutput output, int spawnerActive, RWStructuredBuffer<uint> deadCount)
{
    if (output.alive == 1)
    {
        float velocity = (_CamVelocity * (1 - output.parallaxFactor)) + (_TrainVelocity * output.parallaxFactor);
        output.position.x -= velocity;
        if (output.position.x < _SpawnerMinPos.x)
        {
            if (spawnerActive == 0)
            {
                InterlockedAdd(deadCount[0], 1);
            }
            output.alive = 0;
        }
    }
    else if (spawnerActive == 1)
    {
        output.position.x = _SpawnerMaxPos.x;
        output.alive = 1;
    }
}

//Init
[numthreads(THREADS_PER_GROUP, 1, 1)]
void _F0Init(uint id : SV_DispatchThreadID)
{
    if (id >= _ForegroundParticleCount)
        return;
    
    ZoneOutput output = _F0Output[id];
    InitOutput(id, _ForegroundParticleCount, _F0SpriteCount, FORE_MIN, FORE_SIZE, F0_ID, _F0Input, output);
    _F0Output[id] = output;

}

[numthreads(THREADS_PER_GROUP, 1, 1)]
void _M0Init(uint id : SV_DispatchThreadID)
{
    if (id >= _MiddlegroundParticleCount)
        return;
    
    ZoneOutput output = _M0Output[id];
    InitOutput(id, _MiddlegroundParticleCount, _M0SpriteCount,  MID_MIN, MID_SIZE, M0_ID, _M0Input, output);
    _M0Output[id] = output;
}

