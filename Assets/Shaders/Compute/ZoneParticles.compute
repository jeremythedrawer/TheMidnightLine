static const float F0_ID = 1.0;
static const float M0_ID = 2.0;
static const float M1_ID = 3.0;
static const float M2_ID = 4.0;
static const float M3_ID = 5.0;
static const float B0_ID = 6.0;
static const float B1_ID = 7.0;
static const float B2_ID = 8.0;

RWStructuredBuffer<ZoneOutput> _F0Output;
RWStructuredBuffer<ZoneOutput> _M0Output;
RWStructuredBuffer<ZoneOutput> _M1Output;
RWStructuredBuffer<ZoneOutput> _M2Output;
RWStructuredBuffer<ZoneOutput> _M3Output;
RWStructuredBuffer<ZoneOutput> _B0Output;
RWStructuredBuffer<ZoneOutput> _B1Output;
RWStructuredBuffer<ZoneOutput> _B2Output;

